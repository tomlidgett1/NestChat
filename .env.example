# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI API Key (for voice memo transcription via Whisper)
OPENAI_API_KEY=sk-xxx

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_ANON_KEY=your_legacy_anon_key_if_needed
SUPABASE_CONVERSATIONS_TABLE=conversations
SUPABASE_USER_PROFILES_TABLE=user_profiles

# Sendblue API
SENDBLUE_API_KEY=your_sendblue_api_key
SENDBLUE_API_SECRET=your_sendblue_api_secret
SENDBLUE_API_BASE_URL=https://api.sendblue.co

# People Data Labs (optional — enriches new users with name/job/company on first message)
PDL_API_KEY=

# Server
PORT=3000

# Sendblue phone numbers this bot runs on (comma-separated, supports multiple)
SENDBLUE_BOT_NUMBERS=+14155551234

# Optional webhook verification
SENDBLUE_WEBHOOK_SECRET=
SENDBLUE_WEBHOOK_SECRET_HEADER=x-sendblue-secret

# Sender phone numbers to ignore (comma-separated) - you'll respond to these manually
IGNORED_SENDERS=+14155555678,+14155559999

# Only respond to these sender numbers (comma-separated) - useful for local dev to avoid double-replies
# Leave empty/unset to respond to everyone
ALLOWED_SENDERS=
