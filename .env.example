# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI API Key (for voice memo transcription via Whisper)
OPENAI_API_KEY=sk-xxx

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_CONVERSATIONS_TABLE=conversations
SUPABASE_USER_PROFILES_TABLE=user_profiles

# Linq API (iMessage provider)
LINQ_API_TOKEN=your_linq_api_token
LINQ_API_BASE_URL=https://api.linqapp.com/api/partner/v3
LINQ_AGENT_BOT_NUMBERS=+14155551234
# Optional: single number for admin “Open in iMessage” if you use several bot numbers (E.164)
NEST_IMESSAGE_NUMBER=

# People Data Labs (optional — enriches new users with name/job/company on first message)
PDL_API_KEY=

# Google OAuth (for Gmail/Calendar integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Gmail push (Pub/Sub topic full name, e.g. projects/PROJECT_ID/topics/TOPIC) — set in Supabase Edge secrets for production
GOOGLE_PUBSUB_TOPIC=

# Microsoft OAuth (for Outlook/Calendar integration)
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret

# Google Maps API Key (for travel_time, places_search, and weather_lookup tools)
GOOGLE_MAPS_API_KEY=

# Supabase server secret key
SUPABASE_SECRET_KEY=

# Same value as SUPABASE_SECRET_KEY when Supabase Edge secrets cannot use that name (reserved)
NEW_SUPABASE_SECRET_KEY=

# Internal server-to-server secret for Edge Function callers, cron, and pg_net
INTERNAL_EDGE_SHARED_SECRET=

# ElevenLabs text-to-speech (morning-brief-audio Edge function — set in Supabase secrets for prod)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional; default eleven_turbo_v2_5
ELEVENLABS_MODEL_ID=

# Brand admin (/admin/brands) — pick any long random string; paste the same value in the unlock screen
NEST_ADMIN_SECRET=

# Server
PORT=3000

# Marketing site (Vite / Vercel). Moment V2 in the admin sidebar opens this origin in a new tab (the site uses frame-ancestors that forbid iframes). Nest GET /admin/moment-v2 also redirects here. Default: https://nest.expert
# NEST_WEBSITE_ORIGIN=http://localhost:5173

# Sender phone numbers to ignore (comma-separated) - you'll respond to these manually
IGNORED_SENDERS=+14155555678,+14155559999

# Only respond to these sender numbers (comma-separated) - useful for local dev to avoid double-replies
# Leave empty/unset to respond to everyone
ALLOWED_SENDERS=
